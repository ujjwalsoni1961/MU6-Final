# ── Supabase ──
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_SERVICE_KEY=your-service-role-key

# ── Thirdweb ──
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id

# ── Chain: Polygon Amoy Testnet (80002) ──
# Switch to 137 for Polygon Mainnet when ready

# ── Contract Addresses (Polygon Amoy) ──
EXPO_PUBLIC_SONG_NFT_ADDRESS=
EXPO_PUBLIC_SPLIT_ADDRESS=
EXPO_PUBLIC_MARKETPLACE_ADDRESS=

# ── App URL ──
# Base URL for email links. Defaults to http://localhost:8081 in dev.
EXPO_PUBLIC_APP_URL=https://mu6.app

# ── Email ──
# Email is sent via Supabase Edge Function (Gmail SMTP).
# No client-side API key needed — secrets are configured on the edge function.
